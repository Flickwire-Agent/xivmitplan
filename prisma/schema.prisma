generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  TANK
  HEALER
  MELEE
  RANGED
  CASTER
}

enum Role {
  USER
  ADMIN
}

enum Category {
  MITIGATION
  HEALING
  SHIELD
  INVULN
  PERSONAL
}

enum SharedSlot {
  REPRISAL
  FEINT
  ADDLE
  RANGED
}

enum EventType {
  RAID_DAMAGE
  TANK_DAMAGE
  POSITIONING_REQUIRED
  AVOIDABLE_AOE
  DEBUFFS
  TARGETED_AOE
  MECHANICS
  OTHER
}

model User {
  id          String   @id @default(cuid())
  auth0Id     String?  @unique
  email       String?
  displayName String?
  role        Role     @default(USER)
  bannedAt    DateTime?
  createdAt   DateTime @default(now())
  plans       Plan[]
}

model Fight {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  patch      String
  bossName   String
  expansion  String
  tier       String
  timestamps Json
  icon       String?
  createdAt  DateTime @default(now())
  plans      Plan[]
}

model Job {
  id        String    @id
  name      String
  role      RoleName
  iconUrl   String?
  abilities       Ability[]
  planCharacters  PlanCharacter[]
}

model Ability {
  id          String      @id @default(cuid())
  name        String
  cooldown    Int
  duration    Int?
  description String?
  iconUrl     String?
  jobId       String?
  role        RoleName?
  category    Category
  sharedSlot  SharedSlot?
  jobs        Job[]
  events      PlanEvent[]
}

model Plan {
  id         String          @id @default(cuid())
  title      String?
  shareId    String?         @unique
  fightId    String
  userId     String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  characters PlanCharacter[]
  events     PlanEvent[]
  fight      Fight           @relation(fields: [fightId], references: [id])
  user       User?           @relation(fields: [userId], references: [id])
}

model PlanCharacter {
  id        String       @id @default(cuid())
  planId    String
  jobId     String
  label     String?
  slotIndex Int
  plan      Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  job       Job          @relation(fields: [jobId], references: [id])
  events    PlanEvent[]
}

model PlanEvent {
  id              String         @id @default(cuid())
  planCharacterId String?
  planId          String?
  timestampIndex  Int
  time            Int            @default(0)
  abilityId       String
  note            String?
  planCharacter   PlanCharacter? @relation(fields: [planCharacterId], references: [id], onDelete: Cascade)
  plan            Plan?          @relation(fields: [planId], references: [id], onDelete: Cascade)
  ability         Ability        @relation(fields: [abilityId], references: [id])
}
