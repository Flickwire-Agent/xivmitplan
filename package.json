{
  "name": "xivmitplan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "import:timeline": "tsx scripts/import-timeline.ts",
    "import:arcadion": "tsx scripts/import-arcadion.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate dev && tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.22.0",
    "@mantine/charts": "~9.3.2",
    "@mantine/core": "~9.3.2",
    "@mantine/hooks": "~9.3.2",
    "@mantine/modals": "~9.3.2",
    "@mantine/notifications": "~9.3.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "postcss-preset-mantine": "~1.18.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "~21.0.2",
    "@commitlint/config-conventional": "~21.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "~9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "~17.0.7",
    "oxfmt": "~0.55.0",
    "oxlint": "~1.70.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,mts}": "oxlint --fix",
    "*.{ts,tsx,js,jsx,mjs,mts,json,css,md}": "oxfmt"
  }
}
