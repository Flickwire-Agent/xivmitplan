{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "nextjs", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "style": "warn"
  },
  "ignorePatterns": [".next/", "out/", "build/", "node_modules/", "next-env.d.ts"]
}
